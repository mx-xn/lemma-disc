theorem eval_insertionsort_correct (T : Type) [Preorder T] [DecidableEq T] [DecidableRel (LT.lt (α := T))] : SortCorrect (insertionsort : List T -> List T) := by
  intro l
  induction l with
  | nil =>
    constructor
    · simp [insertionsort, Sorted.nil]
    · exact lemma_hint_21
  | cons x xs ih =>
    rcases ih with ⟨hs, hp⟩
    constructor
    ·
      have hins : ∀ ys, Sorted ys → Sorted (insert_ x ys) := by
        intro ys hs'
        induction hs' with
        | nil =>
          simp [insert_]
          exact Sorted.singleton
        | singleton =>
          simp [insert_]
          by_cases h : x < x_1
          · simp [h]
            exact Sorted.cons Sorted.singleton h
          · simp [h]
            exact Sorted.cons Sorted.singleton h
        | cons s hnot ihs =>
          simp [insert_]
          by_cases h : x < a
          · simp [h]
            exact Sorted.cons (Sorted.cons s hnot) h
          · simp [h]
            have hs_tail : Sorted (b :: xs) := Sorted.cons s hnot
            have hrec : Sorted (insert_ x (b :: xs)) := ihs hs_tail
            cases s with
            | singleton =>
              simp [insert_] at hrec ⊢
              by_cases hb : x < b
              · simp [hb] at hrec
                exact Sorted.cons Sorted.singleton hnot
              · simp [hb] at hrec
                exact Sorted.cons hrec hnot
            | cons s' hbna =>
              exact Sorted.cons hrec hbna
      exact hins _ hs
    · exact lemma_hint_3 x xs


